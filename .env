# PostgreSQL — CORRIGÉ
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=0000
POSTGRES_DB=gestion-dossiers-juridique

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=legal_documents
QDRANT_VECTOR_SIZE=1024

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32

# Ollama
OLLAMA_URL=http://localhost:11434
CHAT_MODEL=llama3.2:latest
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=300

# Router
ROUTER_MODEL=llama3.2:latest

# RAG
TOP_K_RESULTS=5

# API
LARAVEL_API_KEY=laravel-internal-key
DEBUG=True

# PDF
PDF_STORAGE_PATH=C:/Users/salma/gestion-dossier-juridique/public/storage/documents